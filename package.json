{
  "name": "hotbox",
  "private": true,
  "version": "0.0.0",
  "description": "Internal Railway-style PaaS for Hetzner.",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "db:migrate": "pnpm -F @hotbox/db migrate",
    "seed": "pnpm -F @hotbox/api seed",
    "dev:api": "pnpm -F @hotbox/api dev",
    "dev:web": "pnpm -F @hotbox/web dev",
    "dev:pg:up": "docker compose -f infra/compose.dev.yml up -d",
    "dev:pg:down": "docker compose -f infra/compose.dev.yml down"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "vitest": "^2.1.5"
  }
}
