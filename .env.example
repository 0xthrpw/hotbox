# Copy to .env and fill in. .env is gitignored.

# --- core ---
DATABASE_URL=postgres://hotbox:hotbox@127.0.0.1:5433/hotbox
HOTBOX_MASTER_KEY_PATH=./master.key
HOST_ID=                      # uuid; created during seed, paste back here

# --- api ---
PORT=3000
WEB_ORIGIN=http://localhost:3001
LOG_LEVEL=info

# --- web ---
HOTBOX_API_URL=http://127.0.0.1:3000

# --- rpc-proxy ---
UPSTREAM_URL=http://erigon:8545

# --- seed (only used by `pnpm seed`) ---
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_HOST_NAME=local
SEED_HOST_ADDRESS=127.0.0.1

# --- prod-only (compose.hotbox.yml) ---
ACME_EMAIL=
HOTBOX_WEB_HOST=hotbox.example
HOTBOX_API_HOST=hotbox-api.example
HOTBOX_PG_PASSWORD=
HOTBOX_HOST_ID=
HOTBOX_REPO=your-gh-org/hotbox
HOTBOX_VERSION=latest
